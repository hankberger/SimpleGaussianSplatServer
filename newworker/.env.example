# SplatApp v2 worker config. Copy to .env and edit. All vars are SPLAT_-prefixed
# (see splatworker/config.py for the full list + docs).

# --- Queue (omit to run as a direct-upload worker for the benchmark app) ---
# SPLAT_QUEUE_URL=https://<your-render-queue>.workers.dev
# SPLAT_QUEUE_API_KEY=<WORKER_API_KEY>

# --- Trainer ---
# SPLAT_LICHTFELD_STRATEGY=mrnf        # mrnf | mcmc | igs+
# SPLAT_LICHTFELD_MAX_CAP=0            # >0 to bound Gaussian count
# SPLAT_LICHTFELD_TIMEOUT_S=3600
# SPLAT_LICHTFELD_EXTRA_ARGS=

# --- Pipeline ---
# SPLAT_DEFAULT_MAX_FRAMES=120
# SPLAT_DEFAULT_RESOLUTION=1280
# SPLAT_DEFAULT_TRAINING_ITERATIONS=30000
# SPLAT_COLMAP_MATCHER=exhaustive      # exhaustive | sequential
# SPLAT_DROP_BLURRY=false

# --- GPU ---
# SPLAT_GPU_DEVICE=cuda:0
